generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String?
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  emailVerified Boolean  @default(false)

  storageUsedBytes BigInt @default(0)

  hasCompletedOnboarding Boolean @default(false) @map("has_completed_onboarding")

  conversations Conversation[]
  documents     Document[]
  projects      Project[]
  projectChats  ProjectConversation[]
  settings      Setting[]
  managedSubscriptions Subscription[]

  orgMembers        OrganizationMember[]
  departmentMembers DepartmentMember[]
  orgConversations  OrgConversation[]
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime

  @@index([email])
}

model Setting {
  id     String  @id @default(cuid())
  key    String
  value  String?
  userId String
  user   User    @relation(fields: [userId], references: [id])

  @@unique([userId, key])
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  openaiApiKey String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  storageUsedBytes BigInt @default(0) @map("storage_used_bytes")

  members      OrganizationMember[]
  invites      OrganizationInvite[]
  departments  Department[]
  projects     Project[]
  documents    Document[]
  conversations OrgConversation[]
  subscription Subscription?

  @@index([name])
}

model OrganizationMember {
  id               String   @id @default(cuid())
  orgId            String
  userId           String
  role             String   @default("employee")
  lastDepartmentId String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastDepartment Department?  @relation(fields: [lastDepartmentId], references: [id], onDelete: SetNull)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model OrganizationInvite {
  id            String    @id @default(cuid())
  orgId         String
  email         String
  role          String    @default("employee")
  departmentIds String[]  @default([])
  token         String    @unique
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([token])
}

model Department {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization         Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members              DepartmentMember[]
  documents            Document[]
  projects             Project[]
  lastVisitedByMembers OrganizationMember[]

  @@unique([orgId, name])
  @@index([orgId])
}

model DepartmentMember {
  id           String   @id @default(cuid())
  departmentId String
  userId       String
  role         String   @default("member")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

model OrgConversation {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  title     String?
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     OrgMessage[]

  @@index([orgId])
  @@index([userId])
}

model OrgMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation OrgConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  userId      String

  scope        String @default("org")
  orgId        String
  departmentId String

  documents    Document[]
  topics       Topic[]
  user         User                  @relation(fields: [userId], references: [id])
  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  projectChats ProjectConversation[]

  @@unique([departmentId, name])
  @@index([scope])
  @@index([orgId])
  @@index([departmentId])
}

model Document {
  id        String   @id @default(cuid())
  filename  String?
  filePath  String?  @map("file_path")
  content   String?
  summary   String?
  status    String?  @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  starred   Int?     @default(0)
  userId    String
  projectId String?
  selected  Int      @default(1)

  visibility String @default("private")

  scope        String  @default("project")
  orgId        String?
  departmentId String?
  lifecycle    String  @default("published")
  category     String?

  chunks        Chunk[]
  conversations Conversation[]
  topicDocument TopicDocument?
  project       Project?       @relation(fields: [projectId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  organization  Organization?  @relation(fields: [orgId], references: [id], onDelete: SetNull)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([orgId])
  @@index([departmentId])
  @@index([lifecycle])
  @@index([category])
}

model Chunk {
  id           String                       @id @default(cuid())
  chunkIndex   Int?                         @map("chunk_index")
  text         String?
  summary      String?
  embedding    Json?
  embeddingVec Unsupported("vector(1536)")? @map("embedding_vec")
  metadata     Json?
  documentId   String                       @map("document_id")
  document     Document                     @relation(fields: [documentId], references: [id])

  @@index([documentId])
}

model Conversation {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @map("created_at")
  userId     String
  documentId String?   @map("document_id")
  document   Document? @relation(fields: [documentId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  messages   Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String?
  content        String?
  status         String?      @default("done")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model ProjectConversation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now()) @map("created_at")
  userId    String
  projectId String?          @map("project_id")
  project   Project?         @relation(fields: [projectId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  messages  ProjectMessage[]
}

model ProjectMessage {
  id             String              @id @default(cuid())
  role           String?
  content        String?
  status         String?             @default("done")
  createdAt      DateTime            @default(now()) @map("created_at")
  conversationId String              @map("conversation_id")
  conversation   ProjectConversation @relation(fields: [conversationId], references: [id])
}

// Topic Clustering

model Topic {
  id                  String   @id @default(cuid())
  projectId           String
  name                String
  centroidEmbedding   Json?
  keywordDistribution Json?
  documentCount       Int      @default(0)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  topicDocuments TopicDocument[]

  @@index([projectId])
}

model TopicDocument {
  id         String   @id @default(cuid())
  topicId    String
  documentId String   @unique
  confidence Float    @default(0.0)
  assignedAt DateTime @default(now()) @map("assigned_at")

  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

// Subscription Extension

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  storageLimitGb  Int
  priceCents      Int      @default(0)
  currency        String   @default("USD")
  stripePriceId   String   @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  billingInterval String   @default("month")

  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(cuid())
  // Legacy per-user billing key. Nullable + no longer unique going forward;
  // retained only as "who originally purchased this" denormalization once
  // billing moves to orgId. Will be fully retired after the org-mandatory
  // pivot's data migration completes.
  managedByUserId      String?
  orgId                String    @unique
  planId               String
  status               String
  stripeCustomerId     String
  stripeSubscriptionId String
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt

  managedByUser User?        @relation(fields: [managedByUserId], references: [id])
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan          Plan         @relation(fields: [planId], references: [id])
}
