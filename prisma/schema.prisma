generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String?
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  emailVerified Boolean  @default(false)

  storageUsedBytes BigInt @default(0)

  conversations Conversation[]
  documents     Document[]
  projects      Project[]
  projectChats  ProjectConversation[]
  settings      Setting[]
  subscription  Subscription?

  orgMembers        OrganizationMember[]
  departmentMembers DepartmentMember[]
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime

  @@index([email])
}

model Setting {
  id     String  @id @default(cuid())
  key    String
  value  String?
  userId String
  user   User    @relation(fields: [userId], references: [id])

  @@unique([userId, key])
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  openaiApiKey String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members     OrganizationMember[]
  invites     OrganizationInvite[]
  departments Department[]
  projects    Project[]
  documents   Document[]

  @@index([name])
}

model OrganizationMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("employee")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model OrganizationInvite {
  id         String    @id @default(cuid())
  orgId      String
  email      String
  role       String    @default("employee")
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([token])
}

model Department {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members      DepartmentMember[]
  documents    Document[]

  @@unique([orgId, name])
  @@index([orgId])
}

model DepartmentMember {
  id           String   @id @default(cuid())
  departmentId String
  userId       String
  role         String   @default("member")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  userId      String

  scope String  @default("private")
  orgId String?

  documents    Document[]
  topics       Topic[]
  user         User                  @relation(fields: [userId], references: [id])
  organization Organization?         @relation(fields: [orgId], references: [id], onDelete: SetNull)
  projectChats ProjectConversation[]

  @@unique([userId, name])
  @@index([scope])
  @@index([orgId])
}

model Document {
  id        String   @id @default(cuid())
  filename  String?
  filePath  String?  @map("file_path")
  content   String?
  summary   String?
  status    String?  @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  starred   Int?     @default(0)
  userId    String
  projectId String?
  selected  Int      @default(1)

  visibility String @default("private")

  scope        String  @default("private")
  orgId        String?
  departmentId String?
  lifecycle    String  @default("published")
  category     String?

  chunks        Chunk[]
  conversations Conversation[]
  topicDocument TopicDocument?
  project       Project?       @relation(fields: [projectId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  organization  Organization?  @relation(fields: [orgId], references: [id], onDelete: SetNull)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([orgId])
  @@index([departmentId])
  @@index([lifecycle])
  @@index([category])
}

model Chunk {
  id           String                       @id @default(cuid())
  chunkIndex   Int?                         @map("chunk_index")
  text         String?
  summary      String?
  embedding    Json?
  embeddingVec Unsupported("vector(1536)")? @map("embedding_vec")
  metadata     Json?
  documentId   String                       @map("document_id")
  document     Document                     @relation(fields: [documentId], references: [id])

  @@index([documentId])
}

model Conversation {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @map("created_at")
  userId     String
  documentId String?   @map("document_id")
  document   Document? @relation(fields: [documentId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  messages   Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String?
  content        String?
  status         String?      @default("done")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model ProjectConversation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now()) @map("created_at")
  userId    String
  projectId String?          @map("project_id")
  project   Project?         @relation(fields: [projectId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  messages  ProjectMessage[]
}

model ProjectMessage {
  id             String              @id @default(cuid())
  role           String?
  content        String?
  status         String?             @default("done")
  createdAt      DateTime            @default(now()) @map("created_at")
  conversationId String              @map("conversation_id")
  conversation   ProjectConversation @relation(fields: [conversationId], references: [id])
}

// Topic Clustering

model Topic {
  id                  String   @id @default(cuid())
  projectId           String
  name                String
  centroidEmbedding   Json?
  keywordDistribution Json?
  documentCount       Int      @default(0)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  topicDocuments TopicDocument[]

  @@index([projectId])
}

model TopicDocument {
  id         String   @id @default(cuid())
  topicId    String
  documentId String   @unique
  confidence Float    @default(0.0)
  assignedAt DateTime @default(now()) @map("assigned_at")

  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

// Subscription Extension

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  storageLimitGb  Int
  priceCents      Int      @default(0)
  currency        String   @default("USD")
  stripePriceId   String   @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  billingInterval String   @default("month")

  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planId               String
  status               String
  stripeCustomerId     String
  stripeSubscriptionId String
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])
}
